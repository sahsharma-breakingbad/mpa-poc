# ═══════════════════════════════════════════════════════════════
# LLM Service (shared_config.yaml, VesselIntelligenceAgent, RAG pipelines)
# ═══════════════════════════════════════════════════════════════
LLM_SERVICE_ENDPOINT="https://lite-llm.mymaas.net"
LLM_SERVICE_API_KEY="sk-xxxxxxxxxxxxxxxxxxx"
LLM_SERVICE_PLANNING_MODEL_NAME="openai/claude-opus-4-6"
LLM_SERVICE_GENERAL_MODEL_NAME="openai/claude-opus-4-6"
LITELLM_DROP_PARAMS=True

# ═══════════════════════════════════════════════════════════════
# Embedding Service (RAG pipeline - local LM Studio)
# ═══════════════════════════════════════════════════════════════
OPENAI_EMBEDDING_MODEL="text-embedding-qwen3-8b-text-embedding"
OPENAI_EMBEDDING_API_ENDPOINT="http://127.0.0.1:1234/v1"
OPENAI_EMBEDDING_API_KEY="lm-studio"

# ═══════════════════════════════════════════════════════════════
# Qdrant Vector DB
# ═══════════════════════════════════════════════════════════════
QDRANT_URL="http://localhost:6333"
#QDRANT_API_KEY=""
QDRANT_COLLECTION="sam-documents"
QDRANT_EMBEDDING_DIMENSION="4096"
DOCUMENTS_PATH="./documents"

# ═══════════════════════════════════════════════════════════════
# Solace Broker
# ═══════════════════════════════════════════════════════════════
NAMESPACE="solace-agent-mesh-local"
SOLACE_BROKER_URL="ws://localhost:8008"
SOLACE_BROKER_VPN="default"
SOLACE_BROKER_USERNAME="default"
SOLACE_BROKER_PASSWORD="default"
SOLACE_DEV_MODE="False"

# ═══════════════════════════════════════════════════════════════
# SAM Platform & Web UI
# ═══════════════════════════════════════════════════════════════
SESSION_SECRET_KEY="please_change_me_in"
FASTAPI_HOST="127.0.0.1"
FASTAPI_PORT="8000"
FASTAPI_HTTPS_PORT="8443"
SSL_KEYFILE=""
SSL_CERTFILE=""
SSL_KEYFILE_PASSWORD=""
ENABLE_EMBED_RESOLUTION="True"
LOGGING_CONFIG_PATH="configs/logging_config.yaml"
PLATFORM_API_HOST="127.0.0.1"
PLATFORM_API_PORT="8082"
PLATFORM_SERVICE_URL="http://localhost:8082"
SAM_AUTHORIZATION_CONFIG='{"authorization_service": {"type": "none"}}'

# ═══════════════════════════════════════════════════════════════
# S3 / SeaweedFS Storage
# ═══════════════════════════════════════════════════════════════
S3_BUCKET_NAME="solace-agent-mesh-local"
S3_ENDPOINT_URL="http://localhost:8333"
S3_REGION="us-east-1"

